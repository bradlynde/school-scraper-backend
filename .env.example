# API URLs for each tool (add these in Vercel Environment Variables)

# Auth service — centralized login. When set, login uses this instead of School API.
NEXT_PUBLIC_AUTH_API_URL=https://auth-service-production.up.railway.app

NEXT_PUBLIC_SCHOOL_API_URL=https://school-scraper-backend-production.up.railway.app
NEXT_PUBLIC_CHURCH_API_URL=https://church-scraper-backend-production.up.railway.app

# LOE Generator — deployed separately (Railway/Vercel). When set, LOE tab loads via iframe.
NEXT_PUBLIC_LOE_API_URL=https://loe-generator-production.up.railway.app
